{
  "name": "simple-graphdb",
  "version": "5.0.0",
  "description": "A lightweight async-first graph database for TypeScript with a pluggable storage provider architecture (InMemory, MongoDB), BFS/DFS traversal, topological sort, DAG detection, and Mermaid diagram export.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:prod": "tsc -p tsconfig.prod.json",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build:prod",
    "test": "jest",
    "perf": "ts-node --project tsconfig.perf.json perf/perfTest.ts",
    "perf:gc": "cross-env TS_NODE_PROJECT=tsconfig.perf.json node --expose-gc -r ts-node/register perf/perfTest.ts"
  },
  "keywords": [
    "graph",
    "database",
    "in-memory",
    "mongodb",
    "typescript",
    "async",
    "traversal",
    "graph-database",
    "graph-data-structure",
    "dag",
    "serialization",
    "topological-sort",
    "mermaid"
  ],
  "peerDependencies": {
    "mongodb": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "mongodb": {
      "optional": true
    }
  },
  "author": "Satya Jugran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/satya-jugran/simple-graphdb"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "jest": "^29.5.0",
    "mongodb": "^7.2.0",
    "mongodb-memory-server": "^11.1.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
